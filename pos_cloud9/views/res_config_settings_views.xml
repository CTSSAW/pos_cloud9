<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_cloud9" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.point_of_sale_cloud9</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//div[@id='o_settings_use_payment_terminals']" position="inside">
                        <div class="col-12 col-lg-6 o_setting_box"
                            id="cloud9_payment_terminal_setting"
                            title="The transactions are processed by Cloud9. Set your Cloud9 credentials on the related payment method.">
                            <div class="o_setting_left_pane">
                                <field name="module_pos_cloud9"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="module_pos_cloud9" string="Cloud9"/>
                                <div class="text-muted">
                                    Accept payments with Cloud9 payment terminal
                                </div>
                            </div>
                        </div>
            </xpath>
        </field>
    </record>
</odoo>
