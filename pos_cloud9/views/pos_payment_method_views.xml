<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_payment_method_view_form_inherit_pos_cloud9" model="ir.ui.view">
        <field name="name">pos.payment.method.form.inherit.cloud9</field>
        <field name="model">pos.payment.method</field>
        <field name="inherit_id" ref="point_of_sale.pos_payment_method_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='use_payment_terminal']" position="after">
                <!-- Adyen -->
                <field name="cloud9_gmid" attrs="{'invisible': [('use_payment_terminal', '!=', 'cloud9')], 'required': [('use_payment_terminal', '=', 'cloud9')]}"/>
                <field name="cloud9_gtid" attrs="{'invisible': [('use_payment_terminal', '!=', 'cloud9')], 'required': [('use_payment_terminal', '=', 'cloud9')]}"/>
                <field name="terminale_type" attrs="{'invisible': [('use_payment_terminal', '!=', 'cloud9')], 'required': [('use_payment_terminal', '=', 'cloud9')]}"/>

                <field name="enable_tips" attrs="{'invisible': [('use_payment_terminal', '!=', 'cloud9')], 'required': [('use_payment_terminal', '=', 'cloud9')]}"/>
                <field name="tip_format" attrs="{'invisible': ['|', ('use_payment_terminal','!=','cloud9'),('enable_tips','=',False)]}"/>

                <field name="tip_percent" attrs="{'invisible': ['|', '|', ('use_payment_terminal', '!=', 'cloud9'), ('enable_tips','=',False), ('tip_format', '=', 'tip_amount')]}"/>
                <field name="tip_amount" attrs="{'invisible': ['|', '|',('use_payment_terminal', '!=', 'cloud9'),  ('enable_tips','=',False), ('tip_format', '=', 'tip_percent')]}"/>
<!--                <field name="adyen_test_mode" attrs="{'invisible': [('use_payment_terminal', '!=', 'cloud9')], 'required': [('use_payment_terminal', '=', 'cloud9')]}"/>-->
            </xpath>
        </field>
    </record>
</odoo>
